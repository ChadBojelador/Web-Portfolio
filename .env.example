# =============================
# Portfolio Chat API - Free-only sample env
# Copy to .env and set your Gemini key.
# =============================

CHAT_API_PORT=3002

# Use Gemini only
AI_PROVIDER_ORDER=gemini

# Gemini free-tier friendly setup
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-1.5-flash

# Disabled paid providers
OPENAI_API_KEY=
XAI_API_KEY=

# Optional (if frontend and API are on different domains)
# VITE_CHAT_API_URL=https://your-api-domain.com
